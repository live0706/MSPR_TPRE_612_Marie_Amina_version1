
# --- Identifiants pour la création de la BDD (PostgreSQL Container) ---
DB_USER=obrail_user
DB_PASSWORD=secret_password
DB_NAME=obrail_warehouse

# --- URL de connexion pour les Applications (API, ETL, Dashboard) ---
# Format : postgresql://user:password@host:port/database
# Notez le "@db" : c'est le nom du service dans docker-compose
DATABASE_URL=postgresql://obrail_user:secret_password@db:5432/obrail_warehouse